{
  "lexicon": 1,
  "id": "tech.waow.vote",
  "defs": {
    "main": {
      "type": "record",
      "key": "any",
      "description": "a vote on a poll",
      "record": {
        "type": "object",
        "required": ["subject", "option", "createdAt"],
        "properties": {
          "subject": {
            "type": "string",
            "format": "at-uri"
          },
          "option": {
            "type": "integer",
            "minimum": 0
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
