{
  "lexicon": 1,
  "id": "tech.waow.poll",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "description": "a poll",
      "record": {
        "type": "object",
        "required": ["text", "options", "createdAt"],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 300
          },
          "options": {
            "type": "array",
            "minLength": 2,
            "maxLength": 10,
            "items": {
              "type": "string",
              "maxLength": 100
            }
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
